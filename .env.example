# Latenide environment configuration — copy this file to ".env" and fill in your key.
#
#   cp .env.example .env        (macOS/Linux)
#   Copy-Item .env.example .env (Windows PowerShell)
#
# Your real ".env" is git-ignored and never uploaded, so your key stays private.

# ---------------------------------------------------------------------------
# Google Gemini API key (optional but recommended)
# Get a free key at: https://aistudio.google.com/app/apikey
# Without it, Latenide still culls/routes photos and builds LUTs — only the
# AI metadata, LUT naming, and editing suggestions are skipped (graceful fallback).
# ---------------------------------------------------------------------------
GEMINI_API_KEY=your_api_key_here

# ---------------------------------------------------------------------------
# Optional tuning (defaults shown — safe to leave as-is or delete)
# ---------------------------------------------------------------------------
# Sharpness cull threshold (Laplacian variance). Higher = stricter.
LATENIDE_THRESHOLD=100.0

# Reject photos where a detected face has closed eyes (1 = on, 0 = off).
LATENIDE_REJECT_CLOSED_EYE=0
